# Копируй в .env и заполни. .env в .gitignore — в репозиторий не попадёт.
# При сборке: ./build-image.sh подхватит переменные из .env (если файл есть).

# Публичный ключ для входа root по SSH (одна строка из ~/.ssh/id_ed25519.pub или id_rsa.pub)
ROOT_SSH_AUTHORIZED_KEYS=""

# OpenRouter API key и модель для ZeroClaw
OPENROUTER_API_KEY="sk-or-v1-dddd"
OPENROUTER_MODEL="x-ai/grok-4.1-fast"

# Источник базового образа Armbian (рабочая ссылка; можно заменить на свою)
ARMBIAN_IMAGE_URL="https://drive.usercontent.google.com/download?id=1qh6CHMCaPRnc4t62QG-ndzBoQxDE3vos&export=download"

# Опционально: тулчейны Pico (RP2040) / Nano (AVR)
# PROVISION_PICO=1
# PROVISION_NANO=1

# Профиль сборки: minimal (по умолчанию) или full
# BUILD_PROFILE=minimal
# Для minimal по умолчанию: IMAGE_SIZE_GB=8, APT_CACHE_GB=2, RUN_APT_UPGRADE=0
# Для full по умолчанию: IMAGE_SIZE_GB=24, APT_CACHE_GB=4, RUN_APT_UPGRADE=1
# Можно явно переопределить:
# IMAGE_SIZE_GB=8
# APT_CACHE_GB=2
# RUN_APT_UPGRADE=0
